    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3"
